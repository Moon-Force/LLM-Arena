# OpenCode Arena — environment sample
# Copy this file and fill in secrets locally:
#   cp .env.example .env
# Never commit .env (it is gitignored).

# -----------------------------------------------------------------------------
# LLM API Keys (leave blank if you only configure keys in the frontend UI)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MIMO_API_KEY=

# -----------------------------------------------------------------------------
# Optional custom Base URLs
# -----------------------------------------------------------------------------
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# -----------------------------------------------------------------------------
# OpenCode runtime
# -----------------------------------------------------------------------------
OPENCODE_ENV=development
OPENCODE_MAX_STEPS=100
OPENCODE_TIMEOUT=300
# Arena uses Docker when the daemon + opencode-model:latest are available.
# Set to 1 only for local debug without containers:
# OPENCODE_FORCE_LOCAL=1

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/opencode.db

# Local dev: redis://localhost:6379
# Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Frontend (used by production build / Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# -----------------------------------------------------------------------------
# Official OpenCode + hard isolation
# -----------------------------------------------------------------------------
# Default binary: llm-arena/node_modules/opencode-ai/bin/opencode(.exe)
# OPENCODE_BIN=D:\path\to\opencode.exe
#
# Isolation of each contestant:
#   auto    — Docker hard isolation if Docker is up, else host process (default)
#   docker  — require Docker; only that model's workspace is mounted in the container
#   process — host process only (logical isolation, weaker)
OPENCODE_ISOLATION=auto
# OPENCODE_IMAGE=opencode-arena-agent:latest
# OPENCODE_MEM=2g
# OPENCODE_CPUS=2
# Official websearch tool (Exa) — also set automatically by the runtime
OPENCODE_ENABLE_EXA=1
