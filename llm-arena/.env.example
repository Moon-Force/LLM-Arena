# OpenCode Arena — environment sample
# Copy this file and fill in secrets locally:
#   cp .env.example .env
# Never commit .env (it is gitignored).

# -----------------------------------------------------------------------------
# LLM API Keys (leave blank if you only configure keys in the frontend UI)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MIMO_API_KEY=

# -----------------------------------------------------------------------------
# Optional custom Base URLs
# -----------------------------------------------------------------------------
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# -----------------------------------------------------------------------------
# OpenCode runtime
# -----------------------------------------------------------------------------
OPENCODE_ENV=development
OPENCODE_MAX_STEPS=100
OPENCODE_TIMEOUT=300

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/opencode.db

# Local dev: redis://localhost:6379
# Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Frontend (used by production build / Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
