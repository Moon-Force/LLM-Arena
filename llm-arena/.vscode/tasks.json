{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: OpenCode API",
      "type": "shell",
      "command": "\"${workspaceFolder}/venv/Scripts/python.exe\" -m opencode.api.server",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}",
          "PYTHONUNBUFFERED": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Uvicorn running on|Application startup complete|Running on)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "llm-arena",
        "clear": true
      },
      "linux": {
        "command": "\"${workspaceFolder}/venv/bin/python\" -m opencode.api.server"
      },
      "osx": {
        "command": "\"${workspaceFolder}/venv/bin/python\" -m opencode.api.server"
      }
    },
    {
      "label": "frontend: Vite",
      "type": "shell",
      "command": "npx vite --host 127.0.0.1 --port 3000",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "BROWSER": "none"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:\\s+https?://|ready in)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "llm-arena",
        "clear": true
      }
    },
    {
      "label": "🚀 Start LLM Arena",
      "detail": "并行启动后端 API (8000) + 前端 Vite (3000)",
      "dependsOn": ["backend: OpenCode API", "frontend: Vite"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
